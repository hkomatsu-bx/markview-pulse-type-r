{
  "name": "markview-pulse-type-r",
  "private": true,
  "version": "1.0.0",
  "license": "MIT",
  "author": "Markview Pulse Type R contributors",
  "type": "module",
  "description": "Markview Pulse Type R - Windows 向け Markdown プレビューア",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "cross-env WDIO_TSCONFIG_PATH=tsconfig.e2e.json wdio run ./wdio.conf.ts",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json --noEmit",
    "coverage": "vitest run --coverage",
    "bench": "vitest bench --run",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "dompurify": "^3.4.12",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@vitest/coverage-v8": "^4.1.10",
    "@wdio/cli": "^9.29.0",
    "@wdio/globals": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.0",
    "@wdio/spec-reporter": "^9.29.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.10",
    "webdriverio": "^9.29.0"
  },
  "overrides": {
    "serialize-javascript": "^7.0.7"
  },
  "engines": {
    "node": "^20.0.0 || ^22.0.0 || >=24.0.0"
  }
}
