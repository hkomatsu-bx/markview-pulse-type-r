{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "メインウィンドウの権限。ファイル選択ダイアログ・イベント受信・現在のファイルをOS既定アプリで開く操作を許可する。",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "dialog:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    }
  ]
}
